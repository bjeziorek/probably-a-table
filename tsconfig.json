{
    "compilerOptions": {
        "jsx": "react-jsx",
        "module": "ESNext",
        "target": "ES2020",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": false,
        "declaration": true,
        "emitDeclarationOnly": false,
        "outDir": "dist",
        "rootDir": "./src",
    },
    "include": [
        "src"
    ]
}